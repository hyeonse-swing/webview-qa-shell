{
  "name": "webview-qa-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:qa": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:qa": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "e2e": "playwright test",
    "native:start": "pnpm --dir native start",
    "native:ios": "pnpm --dir native ios",
    "native:android": "ANDROID_HOME=\"$HOME/Library/Android/sdk\" ANDROID_SDK_ROOT=\"$HOME/Library/Android/sdk\" PATH=\"$HOME/Library/Android/sdk/emulator:$HOME/Library/Android/sdk/platform-tools:$PATH\" pnpm --dir native android",
    "open:ios": "bash scripts/open-ios.sh",
    "open:android": "bash scripts/open-android.sh",
    "doctor": "bash scripts/doctor.sh",
    "android:avds": "\"$HOME/Library/Android/sdk/emulator/emulator\" -list-avds"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.9.3",
    "vitest": "^4.0.15"
  }
}
